# Mr. Jeffrey — environment config. Copy to .env (which is gitignored).
# ★ The LLM API key is NEVER here — it is entered per request in the UI and stored nowhere (LEVEL-1). ★

# Session-signing secret (HMAC for session cookies). REQUIRED in production so sessions survive restarts.
# Generate one:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
MRJ_SECRET=change-me-to-a-long-random-string

# SQLite database path (defaults to ./mrjeffrey.db). Holds users/sessions/work — NEVER any LLM API key.
# MRJ_DB=./mrjeffrey.db
